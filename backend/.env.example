NODE_ENV=development
DEV_OTP_MODE=true
DEV_OTP_EXPOSE_IN_API=true
PORT=5000
DATABASE_URL=postgresql://postgres:vyasriya@localhost:5432/ai_agent
DATABASE_SSL=false
CLIENT_URL=http://localhost:5173

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=7d

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

GOOGLE_CLIENT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@ai-agent.local

FAST2SMS_API_KEY=
FAST2SMS_SENDER_ID=
