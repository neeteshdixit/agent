OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=3
SIGNUP_SESSION_TTL_MINUTES=30
SIGNUP_CLEANUP_INTERVAL_MS=600000

